{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "codetitans",
  "compatibility_date": "2026-06-25",
  "observability": {
    "enabled": true
  },
  "main": "dist/server/server.js",
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
